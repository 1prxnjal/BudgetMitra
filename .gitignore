# 🔒 BudgetMitra .gitignore
# This file prevents sensitive and bulky files from being uploaded to GitHub.

# --- Backend (Python) ---
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.env
backend/venv/
backend/env/
backend/.pytest_cache/

# --- Frontend (Node/React) ---
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# --- System / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log
.vercel
